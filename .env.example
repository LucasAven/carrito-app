# Copy to .env.local and fill from your Supabase project dashboard
# (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. Only needed locally for the one-time legacy backfill
# (scripts/import-legacy.mjs); it bypasses RLS, so never ship it to the client.
SUPABASE_SERVICE_ROLE_KEY=

# SMTP for local Supabase auth emails (supabase start reads these for the
# env(...) substitutions in supabase/config.toml). Use a dedicated Gmail account
# with 2-Step Verification on and an App Password (16 chars). For the HOSTED
# project, set these in the Dashboard instead (Project Settings > Authentication >
# SMTP Settings), not here.
GMAIL_SMTP_USER=
GMAIL_APP_PASSWORD=

# iCloud share links to the signed hands-free shortcuts, one per kind. Each
# shortcut's Import Question asks the person for their token on add, so the same
# links work for everyone. Get each from the Shortcuts app: Share, Copy iCloud
# Link.
NEXT_PUBLIC_SIRI_VENTA_URL=
NEXT_PUBLIC_SIRI_GASTO_URL=
